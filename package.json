{
  "name": "n8n-nodes-gigachat",
  "version": "2.0.0",
  "description": "n8n community nodes for GigaChat (Sber AI)",
  "keywords": ["n8n-community-node-package", "gigachat", "sber", "n8n-nodes"],
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint nodes credentials --ext .ts",
    "format": "prettier --write ."
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GigaChatApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GigaChat/GigaChat.node.js",
      "dist/nodes/LmGigaChat/LmGigaChat.node.js",
      "dist/nodes/EmGigaChat/EmGigaChat.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "axios": "^1.12.0",
    "uuid": "^9.0.0"
  }
}
